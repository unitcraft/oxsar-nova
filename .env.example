# ===== Server =====
SERVER_ADDR=:8080
SERVER_ENV=dev
LOG_LEVEL=debug

# ===== Database (PostgreSQL 16) =====
DB_URL=postgres://oxsar:oxsar@localhost:5432/oxsar?sslmode=disable

# ===== Redis 7 =====
REDIS_URL=redis://localhost:6379/0

# ===== Auth =====
JWT_SECRET=change-me-in-production-to-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ===== OAuth2 (optional in v1) =====
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# ===== Game =====
GAMESPEED=0.75
UNIVERSE_NAME=Nova
DEATHMATCH=false
NUM_GALAXIES=8
NUM_SYSTEMS=600

# ===== SMTP (optional) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@oxsar-nova.local
