# Пример .env для docker-compose.multiverse.yml
# Скопируйте в deploy/.env и заполните реальными значениями.
# Никогда не коммитьте этот файл с реальными паролями.

IDENTITY_DB_PASSWORD=change_me_identity
IDENTITY_DB_URL=postgres://identitysvc:change_me_identity@identity-db:5432/identitysvc?sslmode=disable

PORTAL_DB_PASSWORD=change_me_portal
PORTAL_DB_URL=postgres://portal:change_me_portal@portal-db:5432/portal?sslmode=disable

UNI01_DB_PASSWORD=change_me_uni01
UNI01_DB_URL=postgres://uni01:change_me_uni01@uni01-db:5432/uni01?sslmode=disable

UNI02_DB_PASSWORD=change_me_uni02
UNI02_DB_URL=postgres://uni02:change_me_uni02@uni02-db:5432/uni02?sslmode=disable
