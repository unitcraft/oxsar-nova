.env
src/cache/
public/assets/
docker/mysql_data/
*.log

# План 43 Ф.1: Composer vendor/ — генерируется composer install при сборке образа.
# composer.lock коммитится (фиксация версий зависимостей для CI/прода).
vendor/

# Полный дамп legacy БД для dev — тяжёлый, не для коммита
legacy_dump.sql
*.dump.sql

# Снимки legacy для UI-сравнения (содержат реальные emails/passwords/IP — PII).
# Каждый разработчик генерит локально через tools/snapshot-legacy-user.sh.
migrations/fixtures/test-user-snapshot.sql
migrations/fixtures/*.snapshot.sql

# Output compare-with-legacy.sh — большой (HTML × 41 страниц × 2),
# регенерится; cookies — sensitive.
tools/compare-output/
